# Copy this file to .env for local testing.
# On Railway, set these as Variables in your project settings instead —
# Railway never reads .env, but the values map 1:1.

# Required — your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — your Tavily API key (https://tavily.com). If left blank, the
# server still works, it just never adds live web search results.
TAVILY_API_KEY=

# Optional — shared secret required from the front end as the
# "X-Client-Secret" header. Leave blank to disable this check.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Then set the SAME value in the CLIENT_SECRET constant inside
# frontend/index.html and frontend/voice.html.
CLIENT_SECRET=

# Optional — tune how many /counterpart requests one visitor can make.
# Defaults: 60 requests per 15 minutes.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=60

# Optional — comma-separated list of allowed front-end origins, e.g.
#   https://my-company-counterpart.netlify.app
# Leave blank to accept requests from any origin.
ALLOWED_ORIGIN=

# Railway sets this automatically — only needed for local testing.
PORT=3000
